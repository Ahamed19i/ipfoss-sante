
{
  "entities": {
    "news": {
      "title": "Actualités",
      "description": "Articles d'actualités de l'école",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Titre de l'article" },
        "excerpt": { "type": "string", "description": "Résumé court" },
        "content": { "type": "string", "description": "Contenu complet en markdown" },
        "image": { "type": "string", "description": "URL de l'image de couverture" },
        "date": { "type": "string", "format": "date-time", "description": "Date de publication" },
        "category": { "type": "string", "description": "Catégorie de l'article" },
        "author": { "type": "string", "description": "Auteur de l'article" }
      },
      "required": ["title", "excerpt", "content", "date", "category"]
    },
    "applications": {
      "title": "Candidatures",
      "description": "Candidatures envoyées par les étudiants",
      "type": "object",
      "properties": {
        "fullName": { "type": "string", "description": "Nom complet" },
        "email": { "type": "string", "format": "email", "description": "Email de contact" },
        "phone": { "type": "string", "description": "Numéro de téléphone" },
        "formation": { "type": "string", "description": "Formation choisie" },
        "motivation": { "type": "string", "description": "Lettre de motivation" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "accepted", "rejected"], "description": "Statut de la candidature" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Date de soumission" }
      },
      "required": ["fullName", "email", "phone", "formation", "createdAt"]
    },
    "users": {
      "title": "Utilisateurs",
      "description": "Profils utilisateurs et rôles",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "editor", "user"] },
        "displayName": { "type": "string" }
      },
      "required": ["email", "role"]
    },
    "formations": {
      "title": "Formations",
      "description": "Programmes de formation proposés par l'école",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Nom de la formation" },
        "category": { "type": "string", "description": "Catégorie (infirmiers, biomedecine, sante-publique)" },
        "description": { "type": "string", "description": "Description courte" },
        "detailedProgram": { "type": "string", "description": "Programme détaillé (Markdown)" },
        "modules": { "type": "string", "description": "Modules / spécialités (Markdown)" },
        "fees": { "type": "string", "description": "Frais de scolarité" },
        "duration": { "type": "string", "description": "Durée de la formation" },
        "degree": { "type": "string", "description": "Diplôme délivré" },
        "outcomes": { "type": "array", "items": { "type": "string" }, "description": "Débouchés" },
        "requirements": { "type": "string", "description": "Conditions d'admission" },
        "brochureUrl": { "type": "string", "description": "URL du fichier PDF téléchargeable" }
      },
      "required": ["title", "category", "description", "duration", "degree"]
    },
    "leads": {
      "title": "Leads",
      "description": "Prospects ayant téléchargé une brochure",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "formationId": { "type": "string", "description": "ID de la formation concernée" },
        "formationTitle": { "type": "string", "description": "Titre de la formation concernée" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "email", "phone", "formationId", "createdAt"]
    }
  },
  "firestore": {
    "/news/{newsId}": {
      "schema": "news",
      "description": "Collection des actualités"
    },
    "/applications/{applicationId}": {
      "schema": "applications",
      "description": "Collection des candidatures"
    },
    "/users/{userId}": {
      "schema": "users",
      "description": "Collection des profils utilisateurs"
    },
    "/formations/{formationId}": {
      "schema": "formations",
      "description": "Collection des formations"
    },
    "/leads/{leadId}": {
      "schema": "leads",
      "description": "Collection des leads (prospects)"
    }
  }
}
